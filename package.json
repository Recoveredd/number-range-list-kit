{
  "name": "number-range-list-kit",
  "version": "0.1.0",
  "description": "Parse comma-separated integer range lists with normalized segments and diagnostics.",
  "keywords": [
    "number-range",
    "numeric-range",
    "range-list",
    "parser",
    "validator",
    "diagnostics",
    "typescript",
    "browser",
    "developer-tools"
  ],
  "type": "module",
  "sideEffects": false,
  "license": "MPL-2.0",
  "author": "Recoveredd",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Recoveredd/number-range-list-kit.git"
  },
  "bugs": {
    "url": "https://github.com/Recoveredd/number-range-list-kit/issues"
  },
  "homepage": "https://github.com/Recoveredd/number-range-list-kit#readme",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "types": "./dist/index.d.ts",
  "files": ["dist", "README.md", "CHANGELOG.md", "LICENSE"],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepack": "npm run build",
    "test": "vitest run --config vitest.config.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@types/node": "^20.12.12",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  }
}
